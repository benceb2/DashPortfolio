# ── Supabase ──────────────────────────────────────────────────────────────────
# Postgres connection string (service role, direct connection)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Supabase project URL (used for JWT verification)
SUPABASE_URL=https://<project-ref>.supabase.co

# Supabase service role key (server-side only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Supabase JWT secret (used to verify auth tokens)
SUPABASE_JWT_SECRET=<your-jwt-secret>

# ── Polygon.io ────────────────────────────────────────────────────────────────
# API key for price data
POLYGON_API_KEY=<your-polygon-api-key>

# ── Redis / BullMQ ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Web app ───────────────────────────────────────────────────────────────────
# Base URL of the API (used by the Vite build)
VITE_API_BASE_URL=http://localhost:3000
